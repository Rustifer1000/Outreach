# Solomon Outreach App - Environment Variables
# Copy to .env and fill in values

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./outreach.db

# News/Mention APIs
MEDIACLOUD_API_KEY=
NEWSAPI_KEY=

# Media Source APIs (Phase 2D)
LISTENNOTES_API_KEY=
YOUTUBE_API_KEY=
SERPAPI_KEY=

# Contact Enrichment (Phase 2)
HUNTER_API_KEY=

# LLM (optional, for bio enrichment)
ANTHROPIC_API_KEY=

# App
DEBUG=false
ENVIRONMENT=development
